<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:SOEM_FrontEnd.ViewModels"
             x:DataType="vm:MotorControlViewModel"
             mc:Ignorable="d" d:DesignWidth="550" d:DesignHeight="350"
             x:Class="SOEM_FrontEnd.Views.MotorControl">

    <!--
      IMPORTANT:
      런타임 DataContext는 상위(ViewModel)에서 주입합니다.
      (MainView에서 MotorControlVm을 바인딩)

      디자인 프리뷰에서만 VM을 직접 생성하고 싶으면 아래 Design.DataContext를 사용할것.
    -->
	
    <Design.DataContext>
        <vm:MotorControlViewModel />
    </Design.DataContext>

    <Border Margin="5"
            BorderBrush="#C5CBD3"
            BorderThickness="1"
            Padding="8">

			<StackPanel Spacing="8">

				<!-- Header (GroupBox.Header 대체) -->
				<Grid ColumnDefinitions="*,Auto">
					<TextBlock Grid.Column="0"
							   Text="{Binding AxisName}"
							   FontWeight="Bold"
							   FontSize="13"
							   VerticalAlignment="Center"/>

				</Grid>

				<!-- Body -->
				<Grid RowDefinitions="Auto,Auto,Auto"
					  ColumnDefinitions="230,260">

					<!-- Current Position -->
					<StackPanel Grid.Row="0" Grid.ColumnSpan="2"
								Orientation="Horizontal"
								Margin="0,6"
								Spacing="5">

						<TextBlock Width="70"
								   Text="Cur Pos"
								   FontWeight="Bold"/>

						<TextBlock Width="110"
								   Text="{Binding CurrentPosition}"
								   FontSize="18"
								   FontWeight="Bold"
								   TextAlignment="Right"/>

						<TextBlock Text="pls"/>

						<!-- InPosition 표시 -->						
                        <Border Margin="24,0,0,0"
                                Padding="6,2"
                                CornerRadius="6"
                                Background="{Binding IsServoOn, Converter={StaticResource BoolToBrushGrayGreen}}">
                            <TextBlock Text="SERVO ON"
                                       Foreground="White"
                                       FontWeight="Bold"
                                       FontSize="9"
                                       VerticalAlignment="Center"/>
                        </Border>

                        <Border Margin="24,0,0,0"
                                Padding="6,2"
                                CornerRadius="6"
                                Background="{Binding IsHomed, Converter={StaticResource BoolToBrushGrayGreen}}">
                            <TextBlock Text="HOME"
                                       Foreground="White"
                                       FontWeight="Bold"
                                       FontSize="9"
                                       VerticalAlignment="Center"/>
                        </Border>

                        <Border Margin="24,0,0,0"
                                Padding="6,2"
                                CornerRadius="6"
                                Background="{Binding IsInPosition, Converter={StaticResource BoolToBrushGrayGreen}}">
                            <TextBlock Text="INP"
                                       Foreground="White"
                                       FontWeight="Bold"
                                       FontSize="9"
                                       VerticalAlignment="Center"/>
                        </Border>

                        <Border Margin="24,0,0,0"
                                Padding="6,2"
                                CornerRadius="6"
                                Background="{Binding HasError, Converter={StaticResource BoolToBrushGrayRed}}">
                            <TextBlock Text="ERR"
                                       Foreground="White"
                                       FontWeight="Bold"
                                       FontSize="9"
                                       VerticalAlignment="Center"/>
                        </Border>

					</StackPanel>

					<!-- Params -->
					<StackPanel Grid.Row="1" Grid.Column="0" Spacing="4">

						<StackPanel Orientation="Horizontal" Spacing="5">
							<TextBlock Width="70" Text="Speed"/>
							<TextBox Width="110" Height="28"
									 Text="{Binding Speed, UpdateSourceTrigger=PropertyChanged}"
									 HorizontalContentAlignment="Right"/>
							<TextBlock Text="pls"/>
						</StackPanel>

						<StackPanel Orientation="Horizontal" Spacing="5">
							<TextBlock Width="70" Text="Acc"/>
							<TextBox Width="110" Height="26"
									 Text="{Binding AccelText}"
									 HorizontalContentAlignment="Right"/>
							<!--<TextBlock Text="ms"/>-->
						</StackPanel>

						<StackPanel Orientation="Horizontal" Spacing="5">
							<TextBlock Width="70" Text="Dec"/>
							<TextBox Width="110" Height="26"
									 Text="{Binding DecelText, UpdateSourceTrigger=PropertyChanged}"
									 HorizontalContentAlignment="Right"/>
							<!--<TextBlock Text="ms"/>-->
						</StackPanel>

						<StackPanel Orientation="Horizontal" Spacing="5">
							<TextBlock Width="70" Text="Inc"/>
							<TextBox Width="110" Height="26"
									 Text="{Binding IncDistanceText, UpdateSourceTrigger=PropertyChanged}"
									 HorizontalContentAlignment="Right"/>
							<TextBlock Text="pls"/>
						</StackPanel>

						<StackPanel Orientation="Horizontal" Spacing="5">
							<TextBlock Width="70" Text="Abs Pos"/>
							<TextBox Width="110" Height="26"
									 Text="{Binding AbsPositionText}"
									 HorizontalContentAlignment="Right"/>
							<TextBlock Text="pls"/>
						</StackPanel>

						<!--<StackPanel Orientation="Horizontal" Margin="0,6,0,0" Spacing="5">
							<TextBlock Width="70" Text="Start Pos"/>
							<TextBox Width="110" Height="26"
									 Text="{Binding StartPositionText}"
									 HorizontalContentAlignment="Right"/>
							<TextBlock Text="pls"/>
						</StackPanel>-->

						<!--<StackPanel Orientation="Horizontal" Spacing="5">
							<TextBlock Width="70" Text="End Pos"/>
							<TextBox Width="110" Height="26"
									 Text="{Binding EndPositionText}"
									 HorizontalContentAlignment="Right"/>
							<TextBlock Text="pls"/>
						</StackPanel>-->
						
					</StackPanel>

					<!-- Buttons -->
					<Grid Grid.Row="1" Grid.Column="1" RowDefinitions="Auto,Auto,Auto,Auto" RowSpacing="6">

						<!-- 리미트 관련 추가. PDO로직도 추가해야됨. 리미트 미사용 설정도-->
						<UniformGrid Grid.Row="0" Columns="3">
							<Border Padding="6,2" CornerRadius="6" Background="{Binding nlim, Converter={StaticResource BoolToBrushGrayRed}}">
								<TextBlock Text="-LIMIT" Foreground="White" FontWeight="Bold" FontSize="9" VerticalAlignment="Center"/>
							</Border>
							<Border Padding="6,2" CornerRadius="6" Background="{Binding org, Converter={StaticResource BoolToBrushGrayGreen}}">
								<TextBlock Text="ORG" Foreground="White" FontWeight="Bold" FontSize="9" VerticalAlignment="Center"/>
							</Border>
							<Border Padding="6,2" CornerRadius="6" Background="{Binding plim, Converter={StaticResource BoolToBrushGrayRed}}">
								<TextBlock Text="+LIMIT" Foreground="White" FontWeight="Bold" FontSize="9" VerticalAlignment="Center"/>
							</Border>
						</UniformGrid>
							
						<!--조그버튼에 떼면 정지하는 로직 있어야됨. 누르고 있는동안에만 이동할것.-->
						<UniformGrid Grid.Row="1" Columns="2">
                        <Button x:Name="JogMinusButton" Content="◀ JOG-" VerticalAlignment="Stretch" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" VerticalContentAlignment="Center"/>
                        <Button x:Name="JogPlusButton" Content="+JOG ▶" VerticalAlignment="Stretch" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" VerticalContentAlignment="Center"/>
                        </UniformGrid>

						<UniformGrid Grid.Row="2" Columns="2">
							<Button Content="◀ INC-" Command="{Binding CmdMoveIncMinus}" VerticalAlignment="Stretch" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" VerticalContentAlignment="Center"/>
							<Button Content="+INC ▶" Command="{Binding CmdMoveIncPlus}"  VerticalAlignment="Stretch" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" VerticalContentAlignment="Center"/>
						</UniformGrid>
						

						<UniformGrid Grid.Row="3" Columns="2">
							<Button Content="Servo ON" Command="{Binding CmdServoOn}" VerticalAlignment="Stretch" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" VerticalContentAlignment="Center"/>
							<Button Content="Servo OFF" Command="{Binding CmdServoOff}" VerticalAlignment="Stretch" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" VerticalContentAlignment="Center"/>
							<Button Content="Alarm Clear" Foreground="Red" Command="{Binding CmdAlarmClear}" VerticalAlignment="Stretch" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" VerticalContentAlignment="Center"/>
							<Button Content="HOME" Command="{Binding CmdHome}" VerticalAlignment="Stretch" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" VerticalContentAlignment="Center"/>
							<!--<Button Height="32" Content="ABS MOVE" Command="{Binding CmdMoveAbs}" IsEnabled="{Binding IsHomed}" VerticalAlignment="Stretch" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" VerticalContentAlignment="Center"/>-->
                            <Button Height="32" Content="ABS MOVE" Command="{Binding CmdMoveAbs}" VerticalAlignment="Stretch" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" VerticalContentAlignment="Center"/>

                            <Button Height="32" Content="STOP" Command="{Binding CmdMoveStop}" VerticalAlignment="Stretch" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" VerticalContentAlignment="Center"/>

							<!--<Button Height="32" Content="Move Start Pos" Command="{Binding CmdMoveToStart}" IsEnabled="{Binding IsHomed}" VerticalAlignment="Stretch" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" VerticalContentAlignment="Center"/>-->
							<!--<Button Height="32" Content="Move End Pos" Command="{Binding CmdMoveToEnd}" IsEnabled="{Binding IsHomed}" VerticalAlignment="Stretch" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" VerticalContentAlignment="Center"/>-->
							<!--<Button Height="32" Content="Repeat" Command="{Binding CmdStartRepeat}" IsEnabled="{Binding IsHomed}" VerticalAlignment="Stretch" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" VerticalContentAlignment="Center"/>-->

							<!--<Button Height="32" Content="Move Start Pos" Command="{Binding CmdMoveToStart}" VerticalAlignment="Stretch" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" VerticalContentAlignment="Center"/>-->
                            <!--<Button Height="32" Content="Move End Pos" Command="{Binding CmdMoveToEnd}" VerticalAlignment="Stretch" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" VerticalContentAlignment="Center"/>-->
                            <!--<Button Height="32" Content="Repeat" Command="{Binding CmdStartRepeat}" VerticalAlignment="Stretch" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" VerticalContentAlignment="Center"/>-->

							<!--<Button Height="32" Content="Repeat Stop" Command="{Binding CmdStopRepeat}" VerticalAlignment="Stretch" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" VerticalContentAlignment="Center"/>-->
							<Border Margin="0,3,0,0" Padding="4" CornerRadius="3"/>
						</UniformGrid>

					</Grid>

				</Grid>
			</StackPanel>
		</Border>

</UserControl>
