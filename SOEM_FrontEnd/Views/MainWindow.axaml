<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:SOEM_FrontEnd.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:views="clr-namespace:SOEM_FrontEnd.Views"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="SOEM_FrontEnd.Views.MainWindow"
        Icon="/Assets/icon-cat-16397242.ico"
        Title="SOEM FrontEnd"
		ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaChromeHints="PreferSystemChrome"
        ExtendClientAreaTitleBarHeightHint="36">
	
	
	<Border Padding="{Binding $parent[views:MainWindow].WindowPadding}">

		<DockPanel>
		<!-- Title bar area -->
		<Grid DockPanel.Dock="Top" Height="36"
			  ColumnDefinitions="Auto,*,Auto,144"
			  VerticalAlignment="Top"
			  Background="DarkSlateGray"
			  PointerPressed="TitleBar_PointerPressed"
			  DoubleTapped="TitleBar_DoubleTapped">

			<!-- App icon -->
			<Image Grid.Column="0"
						Width="16" Height="16"
						Margin="10,0,6,0"
						VerticalAlignment="Center"
						Source="avares://SOEM_FrontEnd/Assets/icon-cat-16397242.ico"/>
			<!-- title -->
			<TextBlock Grid.Column="1"
					   Margin="10,0,0,0"
					   VerticalAlignment="Center"
					   Text="SOEM_FrontEnd"
					   FontWeight="Bold"/>

			<!-- About button (right side) -->
			<Button Grid.Column="2"
					Content="?"
					Margin="0,0,0,0"
					VerticalAlignment="Center"
					Click="About_Click"/>
		</Grid>

		<!-- Main content -->
		<views:MainView Margin="5,5,5,5"/>

	</DockPanel>
	</Border>


</Window>
