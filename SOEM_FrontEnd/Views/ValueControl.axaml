<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
			 xmlns:vm="using:SOEM_FrontEnd.ViewModels"
             mc:Ignorable="d" d:DesignWidth="700" d:DesignHeight="350"
             x:Class="SOEM_FrontEnd.Views.ValueControl"
			 x:DataType="vm:ValueControlViewModel">

	<Grid Margin="10"
	   RowSpacing="6">

		<Grid.RowDefinitions>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="{Binding OutputRowsHeight}"/>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="{Binding InputRowsHeight}"/>
		</Grid.RowDefinitions>

		<TextBlock Grid.Row="0"
                   Text="Outputs / RxPDO / Master → Slave"
                   FontWeight="Bold"
                   FontSize="15"
                   IsVisible="{Binding HasOutputChannels}" />

		<DataGrid Grid.Row="1"
                  ItemsSource="{Binding OutputChannels}"
                  IsVisible="{Binding HasOutputChannels}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  GridLinesVisibility="All"
                  HeadersVisibility="All"
                  ScrollViewer.VerticalScrollBarVisibility="Auto"
                  ScrollViewer.HorizontalScrollBarVisibility="Auto">

			<DataGrid.Columns>
				<DataGridTextColumn Header="Dir"
                                    Binding="{Binding DirectionText}" />

				<DataGridTextColumn Header="CH"
                                    Binding="{Binding ChannelNo}" />

				<DataGridTextColumn Header="Address"
                                    Binding="{Binding AddressText}" />

				<DataGridTextColumn Header="Name"
                                    Binding="{Binding Name}" />

				<DataGridTextColumn Header="Type"
                                    Binding="{Binding DataType}" />

				<DataGridTextColumn Header="RawType"
                                    Binding="{Binding RawTypeText}" />

				<DataGridTextColumn Header="Byte"
                                    Binding="{Binding ByteOffset}" />

				<DataGridTextColumn Header="Raw"
                                    Binding="{Binding RawText}" />
			</DataGrid.Columns>
		</DataGrid>

		<TextBlock Grid.Row="2"
                   Text="Inputs / TxPDO / Slave → Master"
                   FontWeight="Bold"
                   FontSize="15"
                   Margin="0,8,0,0"
                   IsVisible="{Binding HasInputChannels}" />

		<DataGrid Grid.Row="3"
                  ItemsSource="{Binding InputChannels}"
                  IsVisible="{Binding HasInputChannels}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  GridLinesVisibility="All"
                  HeadersVisibility="All"
                  ScrollViewer.VerticalScrollBarVisibility="Auto"
                  ScrollViewer.HorizontalScrollBarVisibility="Auto">

			<DataGrid.Columns>
				<DataGridTextColumn Header="Dir"
                                    Binding="{Binding DirectionText}" />

				<DataGridTextColumn Header="CH"
                                    Binding="{Binding ChannelNo}" />

				<DataGridTextColumn Header="Address"
                                    Binding="{Binding AddressText}" />

				<DataGridTextColumn Header="Name"
                                    Binding="{Binding Name}" />

				<DataGridTextColumn Header="Type"
                                    Binding="{Binding DataType}" />

				<DataGridTextColumn Header="RawType"
                                    Binding="{Binding RawTypeText}" />

				<DataGridTextColumn Header="Byte"
                                    Binding="{Binding ByteOffset}" />

				<DataGridTextColumn Header="Raw"
                                    Binding="{Binding RawText}" />
			</DataGrid.Columns>
		</DataGrid>

		<TextBlock Grid.Row="0"
                   Grid.RowSpan="4"
                   Text="표시할 Value PDO가 없습니다."
                   IsVisible="{Binding HasNoChannels}"
                   Foreground="Gray"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center" />
	</Grid>
	
	
</UserControl>
