<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:SOEM_FrontEnd.ViewModels"
			 xmlns:ui="clr-namespace:SOEM_FrontEnd.Util.Logging.UI"
			 xmlns:views="clr-namespace:SOEM_FrontEnd.Views"
			 mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="SOEM_FrontEnd.Views.MainView"
             x:DataType="vm:MainViewModel">
  <Design.DataContext>
    <!-- This only sets the DataContext for the previewer in an IDE,
         to set the actual DataContext for runtime, set the DataContext property in code (look at App.axaml.cs) -->
    <vm:MainViewModel />
  </Design.DataContext>

  <Grid>
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="1*" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="0.2*" />
        <!-- <RowDefinition Height="Auto" /> -->
	  </Grid.RowDefinitions>

      <Grid  Grid.Row="0" Grid.Column="0"  HorizontalAlignment="Stretch">

          <Grid.RowDefinitions>
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
          </Grid.RowDefinitions>
          <Grid.ColumnDefinitions>
              <ColumnDefinition Width="Auto" />
              <ColumnDefinition Width="Auto" /> 
              <ColumnDefinition Width="Auto" /> 

          </Grid.ColumnDefinitions>


          <TextBlock Grid.Row="0" Grid.Column="0" Text="NIC List" FontWeight="Bold" />
          <ComboBox Grid.Row="1" Grid.Column="0" HorizontalAlignment="Stretch" 
                    Width="{Binding NicComboWidth}"
                    ItemsSource="{Binding NICList}" 
                    SelectedItem="{Binding NICSelect, Mode=TwoWay}"/>

          <Button Grid.Row ="1" Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Left" Command="{Binding CMD_SelectNIC}" Content="Select"/>
          <Button Grid.Row ="1" Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Left" Command="{Binding CMD_Test}" Content="Test"/>
      </Grid>


      <Grid Grid.Row="2" Grid.Column="0" >
          <Grid.ColumnDefinitions>
              <ColumnDefinition Width="1*" />
              <ColumnDefinition Width="Auto" />
              <ColumnDefinition Width="3*" />
          </Grid.ColumnDefinitions>

          <ListBox Grid.Column="0" 
                   ScrollViewer.VerticalScrollBarVisibility="Auto"
                   ScrollViewer.HorizontalScrollBarVisibility="Auto"
                   VerticalAlignment="Stretch"
                   HorizontalAlignment="Stretch"
                   ItemsSource="{Binding SlavesListUI}"
                   SelectedIndex="{Binding SelectedSlave, Mode=TwoWay}">
          </ListBox>
          
          <GridSplitter Grid.Column="1"
                        ResizeDirection="Columns"
                        VerticalAlignment="Stretch"
                        Width="5"
                        Background="#404040" />

          <Grid Grid.Column="2">

              <!-- Master -->
              <TabControl IsVisible="{Binding IsMasterSelected}">
                  <TabItem Header="Master Status">
                      <Grid Margin="10" RowDefinitions="Auto,Auto,*" ColumnDefinitions="Auto,*">
                          <TextBlock Grid.Row="0" Grid.Column="0" Text="Selected NIC:" FontWeight="Bold" Margin="0,0,8,6"/>
                          <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding NICSelect}" Margin="0,0,0,6"/>

                          <TextBlock Grid.Row="1" Grid.Column="0" Text="Slave Count:" FontWeight="Bold" Margin="0,0,8,10"/>
                          <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding SlaveCountUI}" Margin="0,0,0,10"/>

                          <Border Grid.Row="2" Grid.ColumnSpan="2" BorderThickness="1" CornerRadius="6" Padding="10">
                              <StackPanel Orientation="Horizontal"
                                          HorizontalAlignment="Left"
                                          VerticalAlignment="Top"
                                          Spacing="8"
                                          Margin="16">

                                  <TextBlock Text="슬레이브 모드 변경" HorizontalAlignment="Center" VerticalAlignment="Center" />

                                  <Button Content="Init" Command="{Binding CMD_MoveToInit}" />
                                  <Button Content="PreOP" Command="{Binding CMD_MoveToPreOp}" />
                                  <Button Content="SafeOP" Command="{Binding CMD_MoveToSafeOp}" />
                                  <Button Content="OP" Command="{Binding CMD_MoveToOp}" />

                              </StackPanel>
                          </Border>



                      </Grid>
                  </TabItem>
              </TabControl>


              <TabControl  IsVisible="{Binding IsSlaveSelected}">

			  <TabItem Header="Slave Status">
              <!--  슬레이브 Status 표시. Text로 걍 질러버리지?  -->
              <ScrollViewer Margin="8"
                            HorizontalScrollBarVisibility="Auto"
                            VerticalScrollBarVisibility="Auto">
                  <!--<SelectableTextBlock
                      Text="{Binding SelectedSlaveData.SlaveInfo}"
                      FontFamily="Consolas"
                      FontSize="12" />-->
              </ScrollViewer>


			  </TabItem>

			  <TabItem Header="SDO">
                <Grid>
					<Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>


                  <DataGrid Grid.Row="0"
                    ItemsSource="{Binding SelectedSlaveData.SdoStore.Rows}"
                    SelectedItem ="{Binding SelectedSDO, Mode=TwoWay}"
                    AutoGenerateColumns="False"
                    IsReadOnly="True"
                    GridLinesVisibility="All"
                    HeadersVisibility="All"
                    >

                <DataGrid.Columns>
                  <DataGridTextColumn Header="Index"
                                      Binding="{Binding Index, StringFormat=0x{0:X4}}" />

                  <DataGridTextColumn Header="SubIndex"
                                      Binding="{Binding SubIndex, StringFormat={}{0:D2}}" />

                  <DataGridTextColumn Header="Name"
                                      Binding="{Binding DisplayName}" /> 

                  <DataGridTextColumn Header="Type"
                                      Binding="{Binding DataType}" />

                  <DataGridTextColumn Header="BitSize"
                                      Binding="{Binding BitSize}" />

				  <!-- Flags. -->
				  <DataGridTextColumn Header="Access"
                                      Binding="{Binding Flags.Access}"/>

                  <DataGridTextColumn Header="Category"
                                      Binding="{Binding Flags.Category}"/>
                  
                  <DataGridTextColumn Header="WriteRestrictions"
                                      Binding="{Binding Flags.WriteRestrictions}"/>

                  <DataGridTextColumn Header="PDO"
                                      Binding="{Binding Flags.PDOMapping}"/>


                  <!--Current Value-->
                  <DataGridTextColumn Header="Value"
                                      Binding="{Binding CurrentValueText}"/>

                  <DataGridTextColumn Header="RawValue"
                                      Binding="{Binding CurrentValueRawHexText}"/>

                  <!-- Status -->
                  <DataGridTextColumn Header="ReadStatus"
                                      Binding="{Binding ReadStatus}"/>

                  <DataGridTextColumn Header="WriteStatus"
                                      Binding="{Binding WriteStatus}"/>

                  <DataGridTextColumn Header="Error"
                                      Binding="{Binding LastErrorText}"/>


				</DataGrid.Columns>


        	  </DataGrid>

					<Border Grid.Row="1" Margin="0,8,0,0" Padding="8" CornerRadius="6" BorderThickness="1">
						<Grid ColumnDefinitions="Auto,Auto,*,Auto,Auto,Auto"
							  RowDefinitions="Auto,Auto"
							  >

							
							<!-- 선택된 주소 표시 --><!--
							<TextBlock Grid.Row="0" Grid.Column="0" Text="Selected:" VerticalAlignment="Center"/>
							<TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding SelectedSdoAddrText}" VerticalAlignment="Center"/>
							-->

                            <!-- 전체 Read 버튼 -->
                            <Button Grid.Row="0" Grid.Column="0" Content="All Read"
                                    Command="{Binding CMD_ReadAllSdoCommand}"/>


							<!-- 단일 Read 버튼 -->
							<Button Grid.Row="0" Grid.Column="1" Content="Selected Read"
									IsEnabled="{Binding CanReadSelectedSdo}"
									Command="{Binding CMD_ReadSelectedSdoCommand}"/>

							<!-- Write 입력 -->
							<TextBox Grid.Row="0" Grid.Column="2"
									 Watermark="Write value (HEX Code Ex: 0x123 DEC Code Ex: 123)"
									 Text="{Binding WriteValueText}"/>

							<!-- Write 버튼 -->
							<Button Grid.Row="0" Grid.Column="3" Content="Write"
									IsEnabled="{Binding CanWriteSelectedSdo}"
									Command="{Binding CMD_WriteSelectedSdoCommand}"/>

							<!-- (옵션) Write 타입/포맷 표시 --><!--
							<TextBlock Grid.Row="0" Grid.Column="5"
									   Text="{Binding SelectedSdoTypeText}"
									   VerticalAlignment="Center"/>

							--><!-- 로그/상태줄(옵션) --><!--
							<TextBlock Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="6"
									   Text="{Binding SdoActionStatusText}"
									   Opacity="0.8"/>-->
                            
						</Grid>
					</Border>

                </Grid>
		  </TabItem>
              
              <TabItem Header="ReMAP">


              </TabItem>

              <TabItem Header="PDO">
				  <!-- PDO설정 및 관련 내용 여기에.-->


              </TabItem>

              <TabItem Header="Control">
                  <!-- PDO에서 설정된 내용 바탕으로 동적UI로 처리.-->
                  <!-- MotorControl.axaml 내부에서 DataContext를 만들지 않도록 수정했기 때문에 여기서 주입합니다. -->
                  <Grid>
                      <Grid.RowDefinitions>
                          <RowDefinition Height="*" />
                          <RowDefinition Height="Auto" />
                      </Grid.RowDefinitions>

                      <!-- 부모 VM(MainViewModel)의 HasMotorControl로 표시/숨김 결정 -->
                      <ContentControl IsVisible="{Binding HasMotorControl}">
                          <!-- 실제 MotorControl은 MotorControlVm을 DataContext로 -->
                          <views:MotorControl DataContext="{Binding MotorControlVm}" />
                      </ContentControl>

                      <TextBlock
                          IsVisible="{Binding HasNoMotorControl}"
                          Text="이 슬레이브는 IMotorCommands(BaseProfile) 프로파일이 없어 MotorControl을 표시하지 않습니다."
                          Margin="10"
                          FontSize="14" />

                      <views:PdoHexDumpView Grid.Row="1" DataContext="{Binding PdoHexDumpVm}"/>

                  </Grid>

			  </TabItem>




		  </TabControl>
          </Grid>

	  </Grid>

      <GridSplitter Grid.Row="3"
                    ResizeDirection="Rows"
                    HorizontalAlignment="Stretch"
                    Height="5"
                    Background="#404040" />
      
      <ListBox Grid.Row="4" Grid.Column="0" 
               x:Name ="LogListBox"
               ItemsSource="{Binding UiLogs}"
               FontFamily="Consolas"
               FontSize="12"
               HorizontalAlignment="Stretch"
               VerticalAlignment="Stretch"
               ScrollViewer.VerticalScrollBarVisibility="Auto"
               ScrollViewer.HorizontalScrollBarVisibility="Auto"
			    ui:AutoFollowTailBehavior.IsEnabled="True"
                ui:AutoFollowTailBehavior.ThresholdPx="32">
          <ListBox.Styles>
              <Style Selector="ListBoxItem">
                  <Setter Property="BorderThickness" Value="0" />
                  <Setter Property="Padding" Value="0" />
                  <Setter Property="Margin" Value="0" />
                  <Setter Property="HorizontalContentAlignment" Value="Stretch" />
              </Style>
          </ListBox.Styles>
      </ListBox>



  </Grid>

</UserControl>

