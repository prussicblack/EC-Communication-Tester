<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:SOEM_FrontEnd.ViewModels"
			 xmlns:ui="clr-namespace:SOEM_FrontEnd.Util.Logging.UI"
			 xmlns:views="clr-namespace:SOEM_FrontEnd.Views"
			 mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="550"
             x:Class="SOEM_FrontEnd.Views.MainView"
             x:DataType="vm:MainViewModel">
  <Design.DataContext>
    <!-- This only sets the DataContext for the previewer in an IDE,
         to set the actual DataContext for runtime, set the DataContext property in code (look at App.axaml.cs) -->
    <vm:MainViewModel />
  </Design.DataContext>

  <Grid>
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="1*" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="0.2*" />
        <!-- <RowDefinition Height="Auto" /> -->
	  </Grid.RowDefinitions>

      <Grid  Grid.Row="0" Grid.Column="0"  HorizontalAlignment="Stretch">

          <Grid.RowDefinitions>
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
          </Grid.RowDefinitions>
          <Grid.ColumnDefinitions>
              <ColumnDefinition Width="Auto" />
              <ColumnDefinition Width="Auto" /> 
              <ColumnDefinition Width="Auto" /> 

          </Grid.ColumnDefinitions>


          <TextBlock Grid.Row="0" Grid.Column="0" Text="NIC List" FontWeight="Bold" />
          <ComboBox Grid.Row="1" Grid.Column="0" HorizontalAlignment="Stretch" 
                    Width="{Binding NicComboWidth}"
                    ItemsSource="{Binding NICList}" 
                    SelectedItem="{Binding NICSelect, Mode=TwoWay}"/>

          <Button Grid.Row ="1" Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Left" Command="{Binding CMD_SelectNIC}" Content="Select"/>
          <Button Grid.Row ="1" Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Left" Command="{Binding CMD_Test}" Content="Test" IsVisible="False"/>
      </Grid>


      <Grid Grid.Row="2" Grid.Column="0" >
          <Grid.ColumnDefinitions>
              <ColumnDefinition Width="1*" />
              <ColumnDefinition Width="Auto" />
              <ColumnDefinition Width="3*" />
          </Grid.ColumnDefinitions>

          <ListBox Grid.Column="0" 
                   ScrollViewer.VerticalScrollBarVisibility="Auto"
                   ScrollViewer.HorizontalScrollBarVisibility="Auto"
                   VerticalAlignment="Stretch"
                   HorizontalAlignment="Stretch"
                   ItemsSource="{Binding SlavesListUI}"
                   SelectedIndex="{Binding SelectedSlave, Mode=TwoWay}">
          </ListBox>
          
          <GridSplitter Grid.Column="1"
                        ResizeDirection="Columns"
                        VerticalAlignment="Stretch"
                        Width="5"
                        Background="#404040" />

          <Grid Grid.Column="2">

              <!-- Master -->
              <TabControl IsVisible="{Binding IsMasterSelected}">
                  <TabItem Header="Master Status">
                      <Grid Margin="10" RowDefinitions="Auto,Auto,Auto,Auto,Auto" ColumnDefinitions="Auto,*">

                          <TextBlock Grid.Row="0" Grid.Column="0" Text="Selected NIC:" FontWeight="Bold" Margin="0,0,8,6"/>
                          <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding NICSelect}" Margin="0,0,0,6"/>

                          <TextBlock Grid.Row="1" Grid.Column="0" Text="Slave Count:" FontWeight="Bold" Margin="0,0,8,10"/>
                          <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding SlaveCountUI}" Margin="0,0,0,10"/>

                          <TextBlock Grid.Row="2" Grid.Column="0" Text="Current State:" FontWeight="Bold" Margin="0,0,8,10"/>
                          
                          <Border Grid.Row="2"
                                  Grid.Column="1"
                                  Background="{Binding MasterEcStateColor}"
                                  CornerRadius="4"
                                  Padding="8,2"
                                  HorizontalAlignment="Left"
                                  Margin="0,0,0,10">
                              <TextBlock Text="{Binding MasterEcStateText}" FontWeight="Bold"/>
                          </Border>


						  <Border Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2" BorderThickness="1" CornerRadius="6" Padding="10">
                              <StackPanel Orientation="Horizontal"
                                          HorizontalAlignment="Left"
                                          VerticalAlignment="Top"
                                          Spacing="8"
                                          Margin="16">

                                  <TextBlock Text="슬레이브 모드 변경" HorizontalAlignment="Center" VerticalAlignment="Center" />

                                  <Button Content="Init" Command="{Binding CMD_MoveToInit}" />
                                  <Button Content="PreOP" Command="{Binding CMD_MoveToPreOp}" />
                                  <Button Content="SafeOP" Command="{Binding CMD_MoveToSafeOp}" />
                                  <Button Content="OP" Command="{Binding CMD_MoveToOp}" />

                              </StackPanel>
                          </Border>


						  <Border Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="2" Padding="8" Margin="4" BorderBrush="#555" BorderThickness="1" CornerRadius="4">
							  <StackPanel Spacing="6">

								  <TextBlock Text="PDO Runtime" FontWeight="Bold" FontSize="15" />

								  <Grid ColumnDefinitions="140,120,140,120" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto" RowSpacing="4" ColumnSpacing="8">

									  <TextBlock Grid.Row="0" Grid.Column="0" Text="Running" />
									  <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding PdoIsRunning}" />

									  <TextBlock Grid.Row="0" Grid.Column="2" Text="Loop Count" />
									  <TextBlock Grid.Row="0" Grid.Column="3" Text="{Binding PdoLoopCount}" />

									  <TextBlock Grid.Row="1" Grid.Column="0" Text="Last Period" />
									  <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding PdoLastPeriodUs, StringFormat='{}{0} us'}" />

									  <TextBlock Grid.Row="1" Grid.Column="2" Text="Target Period" />
									  <TextBlock Grid.Row="1" Grid.Column="3" Text="{Binding PdoTargetPeriodUs, StringFormat='{}{0} us'}" />

									  <TextBlock Grid.Row="2" Grid.Column="0" Text="Min Period" />
									  <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding PdoMinPeriodUs, StringFormat='{}{0} us'}" />

									  <TextBlock Grid.Row="2" Grid.Column="2" Text="Max Period" />
									  <TextBlock Grid.Row="2" Grid.Column="3" Text="{Binding PdoMaxPeriodUs, StringFormat='{}{0} us'}" />

									  <TextBlock Grid.Row="3" Grid.Column="0" Text="Avg Period" />
									  <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding PdoAvgPeriodUs, StringFormat='{}{0} us'}" />

									  <TextBlock Grid.Row="3" Grid.Column="2" Text="Last WKC" />
									  <TextBlock Grid.Row="3" Grid.Column="3"
												 Text="{Binding PdoWkcText}" />

									  <TextBlock Grid.Row="4" Grid.Column="0" Text="WKC Error" />
									  <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding PdoWkcErrorCount}" />

									  <TextBlock Grid.Row="4" Grid.Column="2" Text="Overrun" />
									  <TextBlock Grid.Row="4" Grid.Column="3" Text="{Binding PdoOverrunCount}" />

									  <TextBlock Grid.Row="5" Grid.Column="0" Text="Last Update" />
									  <TextBlock Grid.Row="5" Grid.Column="1"
												 Grid.ColumnSpan="3"
												 Text="{Binding PdoLastUpdateText}" />
								  </Grid>

								  <StackPanel Orientation="Horizontal"
											  Spacing="8">
									  <CheckBox Content="PDO 통계를 UI 로그에도 출력"
												IsChecked="{Binding IsPdoStatsUiLogEnabled}" />

									  <Button Content="Max Reset"
											  Command="{Binding ResetPdoStatsCommand}" />
									  
								  </StackPanel>

								  
							  </StackPanel>
						  </Border>
						  
						  
                      </Grid>
                  </TabItem>
              </TabControl>


              <TabControl  IsVisible="{Binding IsSlaveSelected}">

			  <TabItem Header="Slave Status">
              <!--  슬레이브 Status 표시. Text로 걍 질러버리지?  -->
              <ScrollViewer Margin="8"
                            HorizontalScrollBarVisibility="Auto"
                            VerticalScrollBarVisibility="Auto">
                  <!--<SelectableTextBlock
                      Text="{Binding SelectedSlaveData.SlaveInfo}"
                      FontFamily="Consolas"
                      FontSize="12" />-->
              </ScrollViewer>


			  </TabItem>

			  <TabItem Header="SDO">
                <Grid>
					<Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>


                  <DataGrid Grid.Row="0"
                    ItemsSource="{Binding SelectedSlaveData.SdoStore.Rows}"
                    SelectedItem ="{Binding SelectedSDO, Mode=TwoWay}"
                    AutoGenerateColumns="False"
                    IsReadOnly="True"
                    GridLinesVisibility="All"
                    HeadersVisibility="All"
                    >

                <DataGrid.Columns>
                  <DataGridTextColumn Header="Index"
                                      Binding="{Binding Index, StringFormat=0x{0:X4}}" />

                  <DataGridTextColumn Header="SubIndex"
                                      Binding="{Binding SubIndex, StringFormat={}{0:D2}}" />

                  <DataGridTextColumn Header="Name"
                                      Binding="{Binding DisplayName}" /> 

                  <DataGridTextColumn Header="Type"
                                      Binding="{Binding DataType}" />

                  <DataGridTextColumn Header="BitSize"
                                      Binding="{Binding BitSize}" />

				  <!-- Flags. -->
				  <DataGridTextColumn Header="Access"
                                      Binding="{Binding Flags.Access}"/>

                  <DataGridTextColumn Header="Category"
                                      Binding="{Binding Flags.Category}"/>
                  
                  <DataGridTextColumn Header="WriteRestrictions"
                                      Binding="{Binding Flags.WriteRestrictions}"/>

                  <DataGridTextColumn Header="PDO"
                                      Binding="{Binding Flags.PDOMapping}"/>


                  <!--Current Value-->
                  <DataGridTextColumn Header="Value"
                                      Binding="{Binding CurrentValueText}"/>

                  <DataGridTextColumn Header="RawValue"
                                      Binding="{Binding CurrentValueRawHexText}"/>

                  <!-- Status -->
                  <DataGridTextColumn Header="ReadStatus"
                                      Binding="{Binding ReadStatus}"/>

                  <DataGridTextColumn Header="WriteStatus"
                                      Binding="{Binding WriteStatus}"/>

                  <DataGridTextColumn Header="Error"
                                      Binding="{Binding LastErrorText}"/>


				</DataGrid.Columns>


        	  </DataGrid>

					<Border Grid.Row="1" Margin="0,8,0,0" Padding="8" CornerRadius="6" BorderThickness="1">
						<Grid ColumnDefinitions="Auto,Auto,*,Auto,Auto,Auto"
							  RowDefinitions="Auto,Auto"
							  >

							
							<!-- 선택된 주소 표시 --><!--
							<TextBlock Grid.Row="0" Grid.Column="0" Text="Selected:" VerticalAlignment="Center"/>
							<TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding SelectedSdoAddrText}" VerticalAlignment="Center"/>
							-->

                            <!-- 전체 Read 버튼 -->
                            <Button Grid.Row="0" Grid.Column="0" Content="All Read"
                                    Command="{Binding CMD_ReadAllSdoCommand}"/>


							<!-- 단일 Read 버튼 -->
							<Button Grid.Row="0" Grid.Column="1" Content="Selected Read"
									IsEnabled="{Binding CanReadSelectedSdo}"
									Command="{Binding CMD_ReadSelectedSdoCommand}"/>

							<!-- Write 입력 -->
							<TextBox Grid.Row="0" Grid.Column="2"
									 Watermark="Write value (HEX Code Ex: 0x123 DEC Code Ex: 123)"
									 Text="{Binding WriteValueText}"/>

							<!-- Write 버튼 -->
							<Button Grid.Row="0" Grid.Column="3" Content="Write"
									IsEnabled="{Binding CanWriteSelectedSdo}"
									Command="{Binding CMD_WriteSelectedSdoCommand}"/>
                            
						</Grid>
					</Border>

                </Grid>
		  </TabItem>
              
              <TabItem Header="MAP Status">
				  <Grid Margin="8" RowDefinitions="Auto,*,Auto,*" RowSpacing="6">

					  <TextBlock Grid.Row="0" Text="RxPDO / Outputs / 0x1C12" FontWeight="Bold" />

					  <DataGrid Grid.Row="1" ItemsSource="{Binding RxPdoMapRows}" AutoGenerateColumns="False" IsReadOnly="True"	GridLinesVisibility="All" HeadersVisibility="All">

						  <DataGrid.Columns>
							  <DataGridTextColumn Header="#"
												  Binding="{Binding No}" />

							  <DataGridTextColumn Header="Address"
												  Binding="{Binding AddressText}" />

							  <DataGridTextColumn Header="Name"
												  Binding="{Binding Name}" />

							  <DataGridTextColumn Header="Type"	
												  Binding="{Binding DataType}" />

							  <DataGridTextColumn Header="BitLen"
												  Binding="{Binding BitLength}" />
							  
							  <DataGridTextColumn Header="SDO BitSize"
												  Binding="{Binding SdoBitSize}" />

							  <DataGridTextColumn Header="ByteOffset"
												  Binding="{Binding ByteOffset}" />

							  <DataGridTextColumn Header="BitInByte"
												  Binding="{Binding BitInByte}" />

							  <DataGridTextColumn Header="Raw"
												  Binding="{Binding RawText}" />
						  </DataGrid.Columns>
					  </DataGrid>

					  <TextBlock Grid.Row="2"
								 Text="TxPDO / Inputs / 0x1C13"
								 FontWeight="Bold"
								 Margin="0,8,0,0" />

					  <DataGrid Grid.Row="3"
								ItemsSource="{Binding TxPdoMapRows}"
								AutoGenerateColumns="False"
								IsReadOnly="True"
								GridLinesVisibility="All"
								HeadersVisibility="All">

						  <DataGrid.Columns>
							  <DataGridTextColumn Header="#"
												  Binding="{Binding No}" />

							  <DataGridTextColumn Header="Address"
												  Binding="{Binding AddressText}" />

							  <DataGridTextColumn Header="Name"
												  Binding="{Binding Name}" />

							  <DataGridTextColumn Header="Type"
												  Binding="{Binding DataType}" />

							  <DataGridTextColumn Header="BitLen"
												  Binding="{Binding BitLength}" />

							  <DataGridTextColumn Header="SDO BitSize"
												  Binding="{Binding SdoBitSize}" />

							  <DataGridTextColumn Header="ByteOffset"
												  Binding="{Binding ByteOffset}" />

							  <DataGridTextColumn Header="BitInByte"
												  Binding="{Binding BitInByte}" />

							  <DataGridTextColumn Header="Raw"
												  Binding="{Binding RawText}" />
						  </DataGrid.Columns>
					  </DataGrid>

				  </Grid>
				 

              </TabItem>


              <TabItem Header="Control">
                  <!-- PDO에서 설정된 내용 바탕으로 동적UI로 처리.-->
                  <!-- MotorControl.axaml 내부에서 DataContext를 만들지 않도록 수정했기 때문에 여기서 주입합니다. -->
                  <Grid>
                      <Grid.RowDefinitions>
                          <RowDefinition Height="*" />
                          <RowDefinition Height="Auto" />
                      </Grid.RowDefinitions>

                      <!-- 부모 VM(MainViewModel)의 HasMotorControl로 표시/숨김 결정 -->
                      <ContentControl IsVisible="{Binding HasMotorControl}">
                          <views:MotorControl DataContext="{Binding MotorControlVm}" />
                      </ContentControl>

                      <ContentControl IsVisible="{Binding HasIoControl}">
                          <Grid Margin="10"
                                ColumnDefinitions="*,*"
                                RowDefinitions="Auto,*"
                                ColumnSpacing="10"
                                RowSpacing="6">

                              <TextBlock Grid.Row="0" Grid.Column="0" Text="Outputs (RxPDO)" FontWeight="Bold" />
                              <TextBlock Grid.Row="0" Grid.Column="1" Text="Inputs (TxPDO)" FontWeight="Bold" />

                              <Border Grid.Row="1" Grid.Column="0"
                                      IsVisible="{Binding HasIoOutput}"
                                      BorderThickness="1" CornerRadius="6" Padding="8">
                                  <views:IOControl DataContext="{Binding IoOutputVm}" />
                              </Border>

                              <Border Grid.Row="1" Grid.Column="1"
                                      IsVisible="{Binding HasIoInput}"
                                      BorderThickness="1" CornerRadius="6" Padding="8">
                                  <views:IOControl DataContext="{Binding IoInputVm}" />
                              </Border>
                          </Grid>
                      </ContentControl>


                      <TextBlock IsVisible="{Binding HasNoControl}"
                                 Text="이 슬레이브는 Control UI(IMotorCommands 또는 일반 IO)를 표시할 프로파일이 없습니다."
                                 Margin="10"
                                 FontSize="14" />

                      <views:PdoHexDumpView Grid.Row="1" DataContext="{Binding PdoHexDumpVm}"/>

                  </Grid>

			  </TabItem>




		  </TabControl>
          </Grid>

	  </Grid>

      <GridSplitter Grid.Row="3"
                    ResizeDirection="Rows"
                    HorizontalAlignment="Stretch"
                    Height="5"
                    Background="#404040" />
      
      <ListBox Grid.Row="4" Grid.Column="0" 
               x:Name ="LogListBox"
               ItemsSource="{Binding UiLogs}"
               FontFamily="Consolas"
               FontSize="12"
               HorizontalAlignment="Stretch"
               VerticalAlignment="Stretch"
               ScrollViewer.VerticalScrollBarVisibility="Auto"
               ScrollViewer.HorizontalScrollBarVisibility="Auto"
			    ui:AutoFollowTailBehavior.IsEnabled="True"
                ui:AutoFollowTailBehavior.ThresholdPx="32">
          <ListBox.Styles>
              <Style Selector="ListBoxItem">
                  <Setter Property="BorderThickness" Value="0" />
                  <Setter Property="Padding" Value="0" />
                  <Setter Property="Margin" Value="0" />
                  <Setter Property="HorizontalContentAlignment" Value="Stretch" />
              </Style>
          </ListBox.Styles>
      </ListBox>



  </Grid>

</UserControl>

